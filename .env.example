# Database
DATABASE_URL=postgresql://postgres:changeme@db:5432/spokane_markets?schema=public
POSTGRES_DB=spokane_markets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Auth.js
AUTH_SECRET=generate-a-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth (optional — omit to hide Google sign-in)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth (optional — omit to hide Facebook sign-in)
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
