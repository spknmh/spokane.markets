# Database
DATABASE_URL=postgresql://postgres:changeme@db:5432/spokane_markets?schema=public
POSTGRES_DB=spokane_markets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — omit to hide Google sign-in)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth (optional; omit to hide Facebook sign-in)
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Tag Manager (optional — consent banner shows regardless; when set, Accept enables GTM/GA4)
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Umami (optional — traffic analytics; privacy-focused, no cookies)
# Website ID from Umami dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id-here
# Script URL: default script.js. Override if Umami uses custom TRACKER_SCRIPT_NAME.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
# Optional: comma-separated domains for data-domains (overrides auto-derived list; e.g. spokane.markets,www.spokane.markets,localhost)
# NEXT_PUBLIC_UMAMI_DOMAINS=

# Mapbox (address autofill in event/venue forms)
# Get token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Server Actions — required for Docker/multi-instance. Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── Sentry ──────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Redis (rate limiting) ──────────────────────────────────────────
REDIS_URL=

# ── Backups (optional S3) ─────────────────────────────────────────
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-1
