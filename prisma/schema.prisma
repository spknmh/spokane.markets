generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  USER
  VENDOR
  ORGANIZER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum EventStatus {
  DRAFT
  PENDING
  PUBLISHED
  CANCELLED
  REJECTED
}

enum AttendanceStatus {
  GOING
  INTERESTED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionType {
  SPONSORED
  PARTNERSHIP
  FEATURED
}

enum BadgeRole {
  GLOBAL
  VENDOR
  ORGANIZER
}

enum VendorIntentStatus {
  INTERESTED
  APPLIED
  REQUESTED
  ATTENDING
  WAITLISTED
  DECLINED
  WITHDREW
}

enum IntentVisibility {
  PRIVATE
  PUBLIC
}

enum RosterStatus {
  INVITED
  ACCEPTED
  CONFIRMED
  CANCELLED
}

enum ParticipationMode {
  OPEN
  REQUEST_TO_JOIN
  INVITE_ONLY
  CAPACITY_LIMITED
}

// ─── Auth Models (Auth.js / Prisma Adapter) ──────────────────────────

model User {
  id             String    @id @default(cuid())
  role           Role      @default(USER)
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  accounts               Account[]
  sessions               Session[]
  attendances            Attendance[]
  reviews                Review[]
  photos                 Photo[]
  ownedMarkets           Market[]                @relation("MarketOwner")
  claimRequests          ClaimRequest[]          @relation("ClaimRequester")
  reviewedClaims         ClaimRequest[]          @relation("ClaimReviewer")
  reviewedSubmissions    Submission[]            @relation("SubmissionReviewer")
  vendorProfile          VendorProfile?
  notifications          Notification[]
  vendorClaimRequests    VendorClaimRequest[]    @relation("VendorClaimRequester")
  vendorClaimReviews     VendorClaimRequest[]    @relation("VendorClaimReviewer")
  savedFilters           SavedFilter[]
  favoriteVendors        FavoriteVendor[]
  organizerEvents        Event[]                 @relation("OrganizerEvents")
  reports                Report[]
  auditLogs              AuditLog[]
  rosterApprovals        EventVendorRoster[]     @relation("RosterApprover")
  siteStateUpdates       SiteState[]
  userBadges             UserBadge[]
  notificationPreference NotificationPreference?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model BadgeDefinition {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  description  String?     @db.Text
  icon         String? // Lucide icon name
  requiredRole BadgeRole   @default(GLOBAL)
  criteria     Json? // e.g. { "type": "member_years", "years": 1 }
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  userBadges   UserBadge[]

  @@map("badge_definitions")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // e.g. DELETE_EVENT, APPROVE_REVIEW, UPDATE_USER_ROLE
  targetType String? // EVENT, MARKET, USER, REVIEW, etc.
  targetId   String?
  metadata   Json? // extra context
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Report {
  id         String   @id @default(cuid())
  userId     String
  targetType String // EVENT | MARKET | VENDOR | REVIEW
  targetId   String
  reason     String? // spam | inappropriate | other
  notes      String?  @db.Text
  status     String   @default("PENDING") // PENDING | RESOLVED | DISMISSED
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Domain Models ──────────────────────────────────────────────

model Venue {
  id           String  @id @default(cuid())
  name         String
  address      String
  city         String
  state        String
  zip          String
  lat          Float
  lng          Float
  neighborhood String?
  parkingNotes String?

  events  Event[]
  markets Market[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([neighborhood])
  @@map("venues")
}

model Market {
  id                       String             @id @default(cuid())
  name                     String
  slug                     String             @unique
  venueId                  String
  description              String?            @db.Text
  imageUrl                 String?
  websiteUrl               String?
  facebookUrl              String?
  instagramUrl             String?
  baseArea                 String?
  verificationStatus       VerificationStatus @default(UNVERIFIED)
  ownerId                  String?
  typicalSchedule          String?
  contactEmail             String?
  contactPhone             String?
  participationMode        ParticipationMode  @default(OPEN)
  vendorCapacity           Int?
  publicIntentListEnabled  Boolean            @default(true)
  publicIntentNamesEnabled Boolean            @default(true)
  publicRosterEnabled      Boolean            @default(true)
  rosterClaimRequired      Boolean            @default(false)

  owner         User?          @relation("MarketOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Restrict)
  events        Event[]
  reviews       Review[]
  photos        Photo[]
  claimRequests ClaimRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([venueId])
  @@map("markets")
}

model Event {
  id                       String             @id @default(cuid())
  marketId                 String?
  venueId                  String
  title                    String
  slug                     String             @unique
  description              String?            @db.Text
  startDate                DateTime
  endDate                  DateTime
  timezone                 String? // e.g. America/Los_Angeles
  imageUrl                 String?
  status                   EventStatus        @default(DRAFT)
  recurrenceGroupId        String?
  websiteUrl               String?
  facebookUrl              String?
  participationMode        ParticipationMode?
  vendorCapacity           Int?
  publicIntentListEnabled  Boolean?
  publicIntentNamesEnabled Boolean?
  publicRosterEnabled      Boolean?

  submittedById String?
  market        Market?             @relation(fields: [marketId], references: [id], onDelete: SetNull)
  venue         Venue               @relation(fields: [venueId], references: [id], onDelete: Restrict)
  submittedBy   User?               @relation("OrganizerEvents", fields: [submittedById], references: [id], onDelete: SetNull)
  tags          Tag[]               @relation("EventTags")
  features      Feature[]           @relation("EventFeatures")
  attendances   Attendance[]
  reviews       Review[]
  photos        Photo[]
  vendorEvents  VendorEvent[]
  vendorIntents EventVendorIntent[]
  vendorRoster  EventVendorRoster[]
  promotions    Promotion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([status])
  @@index([status, startDate])
  @@index([slug])
  @@map("events")
}

model Promotion {
  id          String        @id @default(cuid())
  eventId     String?
  type        PromotionType
  sponsorName String?
  imageUrl    String?
  linkUrl     String?
  startDate   DateTime
  endDate     DateTime
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([startDate, endDate])
  @@index([eventId])
  @@map("promotions")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  events Event[] @relation("EventTags")

  @@map("tags")
}

model Feature {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  icon   String?
  events Event[] @relation("EventFeatures")

  @@map("features")
}

// ─── User Engagement Models ──────────────────────────────────────────

model Attendance {
  id      String           @id @default(cuid())
  userId  String
  eventId String
  status  AttendanceStatus

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("attendances")
}

model Review {
  id                  String           @id @default(cuid())
  userId              String
  eventId             String?
  marketId            String?
  rating              Int
  text                String?          @db.Text
  parkingRating       Int?
  varietyRating       Int?
  valueRating         Int?
  crowdingRating      Int?
  weatherPlanRating   Int?
  accessibilityRating Int?
  status              ModerationStatus @default(PENDING)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  photos Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("reviews")
}

model Photo {
  id           String           @id @default(cuid())
  reviewId     String?
  eventId      String?
  marketId     String?
  url          String
  alt          String?
  status       ModerationStatus @default(PENDING)
  uploadedById String

  review     Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  event      Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  market     Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status])
  @@map("photos")
}

// ─── Community & Admin Models ────────────────────────────────────────

model Submission {
  id               String           @id @default(cuid())
  submitterName    String
  submitterEmail   String
  eventTitle       String
  eventDescription String?          @db.Text
  eventDate        String
  eventTime        String
  venueName        String
  venueAddress     String
  facebookUrl      String?
  websiteUrl       String?
  notes            String?          @db.Text
  status           ModerationStatus @default(PENDING)
  reviewerId       String?
  reviewNotes      String?          @db.Text

  reviewer User? @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("submissions")
}

model ClaimRequest {
  id          String           @id @default(cuid())
  marketId    String
  userId      String
  proof       String           @db.Text
  status      ModerationStatus @default(PENDING)
  reviewerId  String?
  reviewNotes String?          @db.Text

  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user     User   @relation("ClaimRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("ClaimReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, marketId])
  @@map("claim_requests")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?   @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

model VendorClaimRequest {
  id              String           @id @default(cuid())
  vendorProfileId String
  userId          String
  proof           String           @db.Text
  status          ModerationStatus @default(PENDING)
  reviewerId      String?
  reviewNotes     String?          @db.Text

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  user          User          @relation("VendorClaimRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewer      User?         @relation("VendorClaimReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, vendorProfileId])
  @@map("vendor_claim_requests")
}

model Subscriber {
  id    String   @id @default(cuid())
  email String   @unique
  areas String[]

  createdAt DateTime @default(now())

  @@map("subscribers")
}

model VendorSurvey {
  id                String  @id @default(cuid())
  vendorType        String
  leadTimeNeeded    String?
  biggestPainPoints String? @db.Text
  missingInfo       String? @db.Text
  willingnessToPay  String?
  contactEmail      String?
  contactName       String?

  createdAt DateTime @default(now())

  @@map("vendor_surveys")
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String    @db.Text
  status    String    @default("PENDING") // PENDING | READ | ARCHIVED
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ─── Milestone 3: Vendor & Organizer Models ─────────────────────────

model VendorProfile {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  businessName       String
  slug               String   @unique
  description        String?  @db.Text
  imageUrl           String?
  websiteUrl         String?
  facebookUrl        String?
  instagramUrl       String?
  contactEmail       String?
  contactPhone       String?
  galleryUrls        String[] @default([])
  specialties        String?
  contactVisible     Boolean  @default(true)
  socialLinksVisible Boolean  @default(true)

  user            User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorEvents    VendorEvent[]
  vendorIntents   EventVendorIntent[]
  vendorRoster    EventVendorRoster[]
  favoriteVendors FavoriteVendor[]
  claimRequests   VendorClaimRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("vendor_profiles")
}

model VendorEvent {
  id              String @id @default(cuid())
  vendorProfileId String
  eventId         String

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([vendorProfileId, eventId])
  @@map("vendor_events")
}

model EventVendorIntent {
  id              String             @id @default(cuid())
  eventId         String
  vendorProfileId String
  status          VendorIntentStatus
  notes           String?            @db.Text
  visibility      IntentVisibility   @default(PRIVATE)

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, vendorProfileId])
  @@index([eventId, status])
  @@index([vendorProfileId, status])
  @@map("event_vendor_intents")
}

model EventVendorRoster {
  id               String       @id @default(cuid())
  eventId          String
  vendorProfileId  String
  status           RosterStatus
  approvedByUserId String?
  approvedAt       DateTime?

  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfile  VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  approvedByUser User?         @relation("RosterApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, vendorProfileId])
  @@index([eventId, status])
  @@map("event_vendor_roster")
}

model SavedFilter {
  id            String   @id @default(cuid())
  userId        String
  name          String
  dateRange     String?
  neighborhoods String[]
  categories    String[]
  features      String[]
  emailAlerts   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saved_filters")
}

model NotificationPreference {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  emailEnabled           Boolean   @default(true)
  inAppEnabled           Boolean   @default(true)
  weeklyDigestEnabled    Boolean   @default(true)
  eventMatchEnabled      Boolean   @default(true)
  favoriteVendorEnabled  Boolean   @default(true)
  organizerAlertsEnabled     Boolean   @default(true)
  vendorRequestAlertsEnabled Boolean   @default(true)
  reviewAlertsEnabled        Boolean   @default(true)
  frequency                  String    @default("immediate")
  quietHoursStart        Int?
  quietHoursEnd          Int?
  emailsPausedAt         DateTime?
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model FavoriteVendor {
  id              String  @id @default(cuid())
  userId          String
  vendorProfileId String
  emailAlerts     Boolean @default(true)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, vendorProfileId])
  @@map("favorite_vendors")
}

// Site-wide config (banners, etc.) — admin-editable
model SiteConfig {
  key   String @id
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@map("site_config")
}

// Maintenance mode: single row, id = "default"
enum MaintenanceMode {
  OFF
  MAINTENANCE_ADMIN_ONLY
  MAINTENANCE_PRIVILEGED
}

model SiteState {
  id              String          @id @default("default")
  mode            MaintenanceMode @default(OFF)
  messageTitle    String          @default("We'll be right back")
  messageBody     String?         @db.Text
  links           Json? // [{ label: string, url: string }]
  eta             DateTime?
  updatedByUserId String?
  updatedAt       DateTime        @updatedAt

  updatedBy User? @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("site_state")
}
