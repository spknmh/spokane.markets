generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  USER
  VENDOR
  ORGANIZER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum MarketMembershipRole {
  OWNER
  MANAGER
  VOLUNTEER
  STAFF
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum EventStatus {
  DRAFT
  PENDING
  PUBLISHED
  CANCELLED
  REJECTED
}

enum AttendanceStatus {
  GOING
  INTERESTED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionType {
  SPONSORED
  PARTNERSHIP
  FEATURED
}

enum BadgeRole {
  GLOBAL
  VENDOR
  ORGANIZER
}

enum BadgeCategory {
  USER_ACHIEVEMENT
  LISTING_COMMUNITY
}

enum VendorIntentStatus {
  INTERESTED
  APPLIED
  REQUESTED
  APPROVED
  ATTENDING
  WAITLISTED
  DECLINED
  WITHDREW
}

enum IntentVisibility {
  PRIVATE
  PUBLIC
}

enum RosterStatus {
  INVITED
  ACCEPTED
  CONFIRMED
  CANCELLED
}

enum ParticipationMode {
  OPEN
  REQUEST_TO_JOIN
  INVITE_ONLY
  CAPACITY_LIMITED
}

enum ListingKind {
  MARKET_BRAND
  EVENT_OCCURRENCE
  BOTH
}

enum OrganizerEventType {
  FARMERS_MARKET
  CRAFT_FAIR
  NIGHT_MARKET
  POP_UP
  HOLIDAY_MARKET
  OTHER
}

enum OccurrenceModel {
  ONE_TIME
  RECURRING
  SEASONAL_SERIES
}

enum IndoorOutdoorMode {
  INDOOR
  OUTDOOR
  HYBRID
}

enum VendorApplicationState {
  NOT_ACCEPTING
  OPEN
  WAITLIST
  CLOSED
}

enum VendorWorkflowMode {
  INTENT_ONLY
  BOTH
}

enum SpecialEventPermitStatus {
  NOT_APPLICABLE
  NOT_REQUIRED
  PENDING
  APPROVED
  UNKNOWN
}

enum RestroomAccess {
  YES
  NO
  NEARBY
  UNKNOWN
}

enum PetPolicy {
  ALLOWED
  RESTRICTED
  PROHIBITED
  UNKNOWN
}

enum ListingEvidenceType {
  SPECIAL_EVENT_PERMIT
  INSURANCE_COI
  HEALTH_PERMIT
  NONPROFIT_DETERMINATION
  OTHER
}

enum ListingEvidenceVisibility {
  ADMIN_ONLY
  ORGANIZER_AND_ADMIN
}

enum ListingModerationNoteVisibility {
  ADMIN_ONLY
  ORGANIZER_VISIBLE
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportEscalationStatus {
  NEW
  TRIAGED
  ESCALATED
  CLOSED
}

enum ReportTargetType {
  EVENT
  MARKET
  VENDOR
  REVIEW
}

enum ContactMessageStatus {
  PENDING
  READ
  ARCHIVED
}

// ─── Auth Models (Better Auth) ──────────────────────────────────────

model User {
  id             String  @id @default(cuid())
  role           Role    @default(USER)
  accountStatus  AccountStatus @default(ACTIVE)
  name           String?
  email          String  @unique
  emailVerified  Boolean @default(false)
  image          String?
  hashedPassword String?

  accounts               Account[]
  sessions               Session[]
  attendances            Attendance[]
  reviews                Review[]
  photos                 Photo[]
  ownedMarkets           Market[]                @relation("MarketOwner")
  marketMemberships      MarketMembership[]
  reviewedSubmissions    Submission[]            @relation("SubmissionReviewer")
  vendorProfile          VendorProfile?
  notifications          Notification[]
  savedFilters           SavedFilter[]
  favoriteVendors        FavoriteVendor[]
  organizerEvents        Event[]                 @relation("OrganizerEvents")
  reports                Report[]
  assignedReports        Report[]                @relation("ReportAssignee")
  auditLogs              AuditLog[]
  rosterApprovals        EventVendorRoster[]     @relation("RosterApprover")
  siteStateUpdates       SiteState[]
  userBadges             UserBadge[]
  notificationPreference NotificationPreference?
  applications           Application[]
  listingModerationNotes ListingModerationNote[] @relation("ListingModerationAuthor")
  uploadedListingEvidences ListingEvidence[]     @relation("ListingEvidenceUploader")
  marketingRenders       MarketingRender[]
  marketingFolders       MarketingFolder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model BadgeDefinition {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  description  String?     @db.Text
  icon         String? // Lucide icon name
  category     BadgeCategory @default(USER_ACHIEVEMENT)
  requiredRole BadgeRole   @default(GLOBAL)
  criteria     Json? // e.g. { "type": "member_years", "years": 1 }
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  userBadges   UserBadge[]
  vendorProfiles VendorProfile[] @relation("VendorProfileListingBadges")
  markets      Market[]    @relation("MarketListingBadges")

  @@map("badge_definitions")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. DELETE_EVENT, APPROVE_REVIEW, UPDATE_USER_ROLE
  targetType String? // EVENT, MARKET, USER, REVIEW, etc.
  targetId   String?
  metadata   Json? // extra context
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Report {
  id         String   @id @default(cuid())
  userId     String?
  assigneeUserId String?
  targetType ReportTargetType
  targetId   String
  reason     String? // spam | inappropriate | other
  notes      String?  @db.Text
  internalNotes String? @db.Text
  severity   ReportSeverity @default(MEDIUM)
  escalationStatus ReportEscalationStatus @default(NEW)
  status     ReportStatus @default(PENDING)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignee User? @relation("ReportAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([escalationStatus])
  @@index([assigneeUserId])
  @@index([targetType, targetId])
  @@map("reports")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  providerId           String
  accountId            String
  accessToken          String?   @db.Text
  refreshToken         String?   @db.Text
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?   @db.Text
  password             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}

// ─── Core Domain Models ──────────────────────────────────────────────

model Neighborhood {
  id        String  @id @default(cuid())
  slug      String  @unique
  label     String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venues  Venue[]  @relation("VenueNeighborhood")
  markets Market[] @relation("MarketBaseArea")

  @@index([isActive, label])
  @@map("neighborhoods")
}

model Venue {
  id           String  @id @default(cuid())
  name         String
  address      String
  city         String
  state        String
  zip          String
  lat          Float
  lng          Float
  neighborhood String?
  parkingNotes String?

  neighborhoodRef Neighborhood? @relation("VenueNeighborhood", fields: [neighborhood], references: [slug], onDelete: SetNull, onUpdate: Cascade)

  events  Event[]
  markets Market[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([name, address])
  @@index([neighborhood])
  @@index([deletedAt])
  @@map("venues")
}

model Market {
  id                       String             @id @default(cuid())
  name                     String
  slug                     String             @unique
  venueId                  String
  description              String?            @db.Text
  imageUrl                 String?
  imageFocalX              Int                @default(50)
  imageFocalY              Int                @default(50)
  websiteUrl               String?
  facebookUrl              String?
  instagramUrl             String?
  baseArea                 String?
  verificationStatus       VerificationStatus @default(UNVERIFIED)
  ownerId                  String?
  typicalSchedule          String?
  contactEmail             String?
  contactPhone             String?
  participationMode        ParticipationMode  @default(OPEN)
  vendorCapacity           Int?
  publicIntentListEnabled  Boolean            @default(true)
  publicIntentNamesEnabled Boolean            @default(true)
  publicRosterEnabled      Boolean            @default(true)
  rosterClaimRequired      Boolean            @default(false)
  listingKind              ListingKind        @default(MARKET_BRAND)
  organizerDisplayName     String?
  organizerPublicContact   Boolean            @default(false)
  eventType                OrganizerEventType?
  occurrenceModel          OccurrenceModel?
  timezone                 String?
  indoorOutdoor            IndoorOutdoorMode?
  shortDescription         String?
  vendorCategoryPolicy     Json?
  vendorApplicationState   VendorApplicationState @default(NOT_ACCEPTING)
  vendorApplicationDeadline DateTime?
  vendorWorkflowMode       VendorWorkflowMode @default(INTENT_ONLY)
  termsAttested            Boolean            @default(false)
  termsAttestedAt          DateTime?
  specialEventPermitStatus SpecialEventPermitStatus @default(UNKNOWN)
  expectedAttendance       Int?
  streetClosureImpact      Boolean            @default(false)
  streetClosureNarrative   String?            @db.Text
  insuranceSummary         String?            @db.Text
  safetyPlanSummary        String?            @db.Text
  sanitationPlan           String?            @db.Text
  cancellationPolicy       String?            @db.Text
  accessibilitySummary     String?            @db.Text
  parkingSummary           String?            @db.Text
  restroomAccess           RestroomAccess?
  petPolicy                PetPolicy?
  paymentMethodsPublic     Json?
  productHighlights        Json?
  typicalVendorCount       String?
  feeModelVendor           String?            @db.Text
  boothLogistics           String?            @db.Text
  communicationChannels    String?            @db.Text
  equityInclusionNotes     String?            @db.Text
  verificationChecklist    Json?
  verificationReviewedAt   DateTime?
  verificationReviewedBy   String?
  complianceFlagged        Boolean            @default(false)
  complianceNotes          String?            @db.Text

  owner         User?          @relation("MarketOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  baseAreaRef   Neighborhood?  @relation("MarketBaseArea", fields: [baseArea], references: [slug], onDelete: SetNull, onUpdate: Cascade)
  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Restrict)
  events        Event[]
  reviews       Review[]
  photos        Photo[]
  memberships   MarketMembership[]
  evidences     ListingEvidence[]       @relation("MarketEvidence")
  moderationNotes ListingModerationNote[] @relation("MarketModerationNotes")
  marketingRenders MarketingRender[]    @relation("MarketingRenderMarket")
  listingCommunityBadges BadgeDefinition[] @relation("MarketListingBadges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([venueId])
  @@index([ownerId])
  @@index([deletedAt])
  @@map("markets")
}

model Event {
  id                       String             @id @default(cuid())
  marketId                 String?
  venueId                  String
  title                    String
  slug                     String             @unique
  description              String?            @db.Text
  startDate                DateTime
  endDate                  DateTime
  imageUrl                 String?
  showImageInList          Boolean            @default(true)
  imageFocalX              Int                @default(50)
  imageFocalY              Int                @default(50)
  status                   EventStatus        @default(DRAFT)
  websiteUrl               String?
  facebookUrl              String?
  instagramUrl             String?
  participationMode        ParticipationMode?
  vendorCapacity           Int?
  publicIntentListEnabled  Boolean?
  publicIntentNamesEnabled Boolean?
  publicRosterEnabled      Boolean?
  listingKind              ListingKind?
  organizerDisplayName     String?
  organizerPublicContact   Boolean            @default(false)
  eventType                OrganizerEventType?
  occurrenceModel          OccurrenceModel?
  timezone                 String?
  indoorOutdoor            IndoorOutdoorMode?
  shortDescription         String?
  vendorCategoryPolicy     Json?
  vendorApplicationState   VendorApplicationState?
  vendorApplicationDeadline DateTime?
  vendorWorkflowMode       VendorWorkflowMode?
  termsAttested            Boolean            @default(false)
  termsAttestedAt          DateTime?
  specialEventPermitStatus SpecialEventPermitStatus?
  expectedAttendance       Int?
  streetClosureImpact      Boolean?
  streetClosureNarrative   String?            @db.Text
  insuranceSummary         String?            @db.Text
  safetyPlanSummary        String?            @db.Text
  sanitationPlan           String?            @db.Text
  cancellationPolicy       String?            @db.Text
  accessibilitySummary     String?            @db.Text
  parkingSummary           String?            @db.Text
  restroomAccess           RestroomAccess?
  petPolicy                PetPolicy?
  paymentMethodsPublic     Json?
  productHighlights        Json?
  typicalVendorCount       String?
  feeModelVendor           String?            @db.Text
  boothLogistics           String?            @db.Text
  communicationChannels    String?            @db.Text
  equityInclusionNotes     String?            @db.Text
  verificationChecklist    Json?
  verificationReviewedAt   DateTime?
  verificationReviewedBy   String?
  complianceFlagged        Boolean            @default(false)
  complianceNotes          String?            @db.Text

  submittedById String?
  market        Market?             @relation(fields: [marketId], references: [id], onDelete: SetNull)
  venue         Venue               @relation(fields: [venueId], references: [id], onDelete: Restrict)
  submittedBy   User?               @relation("OrganizerEvents", fields: [submittedById], references: [id], onDelete: SetNull)
  tags          Tag[]               @relation("EventTags")
  features      Feature[]           @relation("EventFeatures")
  attendances   Attendance[]
  reviews       Review[]
  photos        Photo[]
  vendorEvents  VendorEvent[]
  vendorIntents EventVendorIntent[]
  vendorRoster  EventVendorRoster[]
  promotions    Promotion[]
  scheduleDays  EventScheduleDay[]
  submissionFrom Submission? @relation("SubmissionCreatedEvent")
  evidences     ListingEvidence[]       @relation("EventEvidence")
  moderationNotes ListingModerationNote[] @relation("EventModerationNotes")
  marketingRenders MarketingRender[]     @relation("MarketingRenderEvent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([startDate])
  @@index([status])
  @@index([status, startDate])
  @@index([marketId])
  @@index([submittedById])
  @@index([deletedAt])
  @@map("events")
}

model EventScheduleDay {
  id        String   @id @default(cuid())
  eventId   String
  date      DateTime @db.Date
  startTime String
  endTime   String
  allDay    Boolean  @default(false)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@index([eventId])
  @@map("event_schedule_days")
}

model ListingEvidence {
  id           String                    @id @default(cuid())
  marketId     String?
  eventId      String?
  type         ListingEvidenceType
  title        String?
  fileUrl      String
  visibility   ListingEvidenceVisibility @default(ADMIN_ONLY)
  uploadedById String?
  notes        String?                   @db.Text
  reviewedAt   DateTime?
  reviewedBy   String?

  market    Market? @relation("MarketEvidence", fields: [marketId], references: [id], onDelete: Cascade)
  event     Event?  @relation("EventEvidence", fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("ListingEvidenceUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketId])
  @@index([eventId])
  @@index([type])
  @@index([visibility])
  @@map("listing_evidences")
}

model ListingModerationNote {
  id         String                          @id @default(cuid())
  marketId   String?
  eventId    String?
  authorId   String
  note       String                          @db.Text
  visibility ListingModerationNoteVisibility @default(ADMIN_ONLY)

  market Market? @relation("MarketModerationNotes", fields: [marketId], references: [id], onDelete: Cascade)
  event  Event?  @relation("EventModerationNotes", fields: [eventId], references: [id], onDelete: Cascade)
  author User    @relation("ListingModerationAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketId])
  @@index([eventId])
  @@index([authorId])
  @@index([visibility])
  @@map("listing_moderation_notes")
}

model Promotion {
  id          String        @id @default(cuid())
  eventId     String?
  vendorProfileId String?
  type        PromotionType
  sponsorName String?
  imageUrl    String?
  linkUrl     String?
  startDate   DateTime
  endDate     DateTime
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([startDate, endDate])
  @@index([eventId])
  @@index([vendorProfileId])
  @@map("promotions")
}

model Tag {
  id               String            @id @default(cuid())
  name             String            @unique
  slug             String            @unique
  events           Event[]           @relation("EventTags")

  @@map("tags")
}

model Feature {
  id               String            @id @default(cuid())
  name             String            @unique
  slug             String            @unique
  icon             String?
  events           Event[]           @relation("EventFeatures")

  @@map("features")
}

// ─── User Engagement Models ──────────────────────────────────────────

model Attendance {
  id      String           @id @default(cuid())
  userId  String
  eventId String
  status  AttendanceStatus

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("attendances")
}

model Review {
  id                  String           @id @default(cuid())
  userId              String?
  eventId             String?
  marketId            String?
  rating              Int
  text                String?          @db.Text
  parkingRating       Int?
  varietyRating       Int?
  valueRating         Int?
  crowdingRating      Int?
  weatherPlanRating   Int?
  accessibilityRating Int?
  status              ModerationStatus @default(PENDING)

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  market Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  photos Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([eventId])
  @@index([marketId])
  @@map("reviews")
}

model Photo {
  id           String           @id @default(cuid())
  reviewId     String?
  eventId      String?
  marketId     String?
  url          String
  alt          String?
  status       ModerationStatus @default(PENDING)
  uploadedById String

  review     Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  event      Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  market     Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([uploadedById])
  @@index([eventId])
  @@index([marketId])
  @@map("photos")
}

// ─── Community & Admin Models ────────────────────────────────────────

model Submission {
  id               String           @id @default(cuid())
  submitterName    String
  submitterEmail   String
  eventTitle       String
  eventDescription String?          @db.Text
  eventDate        String
  eventTime        String
  endDate          String?
  endTime          String?
  allDay           Boolean          @default(false)
  /// When set, per-day schedule (same shape as event schedule days). Legacy `eventDate`/`eventTime`/… remain denormalized for list views.
  scheduleDays     Json?
  timezone         String?
  imageUrl         String?
  venueName        String
  venueAddress     String
  venueCity        String?
  venueState       String?
  venueZip         String?
  marketId         String?
  tagIds           String[]         @default([])
  featureIds       String[]        @default([])
  facebookUrl      String?
  instagramUrl     String?
  websiteUrl       String?
  notes            String?          @db.Text
  status           ModerationStatus @default(PENDING)
  reviewerId       String?
  reviewNotes      String?          @db.Text
  createdEventId   String?          @unique

  reviewer User? @relation("SubmissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdEvent Event? @relation("SubmissionCreatedEvent", fields: [createdEventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("submissions")
}

model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String?   @db.Text
  link         String?
  severity     String    @default("info")
  category     String?
  actorId      String?
  objectId     String?
  objectType   String?
  metadata     Json?
  readAt       DateTime?
  archivedAt   DateTime?
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, severity])
  @@index([userId, category])
  @@map("notifications")
}

model Subscriber {
  id    String   @id @default(cuid())
  email String   @unique
  areas String[]

  createdAt DateTime @default(now())

  @@map("subscribers")
}

model VendorSurvey {
  id                String  @id @default(cuid())
  vendorType        String
  leadTimeNeeded    String?
  biggestPainPoints String? @db.Text
  missingInfo       String? @db.Text
  willingnessToPay  String?
  contactEmail      String?
  contactName       String?

  createdAt DateTime @default(now())

  @@map("vendor_surveys")
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String    @db.Text
  status    ContactMessageStatus @default(PENDING)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ─── Milestone 3: Vendor & Organizer Models ─────────────────────────

model VendorProfile {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  businessName       String
  slug               String   @unique
  description        String?  @db.Text
  imageUrl           String?
  imageFocalX        Int      @default(50)
  imageFocalY        Int      @default(50)
  /** Wide cover image; avatar stays `imageUrl` when set. */
  heroImageUrl       String?
  heroImageFocalX    Int      @default(50)
  heroImageFocalY    Int      @default(50)
  websiteUrl         String?
  facebookUrl        String?
  instagramUrl       String?
  contactEmail       String?
  contactPhone       String?
  galleryUrls        String[] @default([])
  specialties        String?
  /** Primary product/category label for discovery (e.g. Produce, Crafts). */
  primaryCategory    String?
  /** Non-precise public area, e.g. city or neighborhood. */
  serviceAreaLabel   String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  contactVisible     Boolean  @default(false)
  socialLinksVisible Boolean  @default(false)

  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  vendorEvents    VendorEvent[]
  vendorIntents   EventVendorIntent[]
  vendorRoster    EventVendorRoster[]
  favoriteVendors FavoriteVendor[]
  promotions      Promotion[]
  marketingRenders MarketingRender[]    @relation("MarketingRenderVendor")
  listingCommunityBadges BadgeDefinition[] @relation("VendorProfileListingBadges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@map("vendor_profiles")
}

model VendorEvent {
  id              String @id @default(cuid())
  vendorProfileId String
  eventId         String

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([vendorProfileId, eventId])
  @@map("vendor_events")
}

model EventVendorIntent {
  id              String             @id @default(cuid())
  eventId         String
  vendorProfileId String
  status          VendorIntentStatus
  notes           String?            @db.Text
  visibility      IntentVisibility   @default(PRIVATE)

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, vendorProfileId])
  @@index([eventId, status])
  @@index([vendorProfileId, status])
  @@map("event_vendor_intents")
}

model EventVendorRoster {
  id               String       @id @default(cuid())
  eventId          String
  vendorProfileId  String
  status           RosterStatus
  approvedByUserId String?
  approvedAt       DateTime?

  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorProfile  VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  approvedByUser User?         @relation("RosterApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, vendorProfileId])
  @@index([eventId, status])
  @@map("event_vendor_roster")
}

model MarketMembership {
  id       String               @id @default(cuid())
  marketId String
  userId   String
  role     MarketMembershipRole @default(OWNER)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketId, userId])
  @@index([userId, role])
  @@map("market_memberships")
}

model SavedFilter {
  id            String   @id @default(cuid())
  userId        String
  name          String
  dateRange     String?
  neighborhoods String[]
  categories    String[]
  features      String[]
  emailAlerts   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_filters")
}

model NotificationPreference {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  emailEnabled               Boolean   @default(true)
  inAppEnabled               Boolean   @default(true)
  inAppOperationalEnabled    Boolean   @default(true)
  inAppDiscoveryEnabled      Boolean   @default(true)
  inAppTrustSafetyEnabled    Boolean   @default(true)
  inAppGrowthEnabled         Boolean   @default(true)
  inAppSystemEnabled         Boolean   @default(true)
  weeklyDigestEnabled        Boolean   @default(true)
  eventMatchEnabled          Boolean   @default(true)
  favoriteVendorEnabled      Boolean   @default(true)
  organizerAlertsEnabled     Boolean   @default(true)
  vendorRequestAlertsEnabled Boolean   @default(true)
  reviewAlertsEnabled        Boolean   @default(true)
  frequency                  String    @default("immediate")
  quietHoursStart            Int?
  quietHoursEnd              Int?
  emailsPausedAt             DateTime?
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model FavoriteVendor {
  id              String  @id @default(cuid())
  userId          String
  vendorProfileId String
  emailAlerts     Boolean @default(true)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, vendorProfileId])
  @@index([vendorProfileId])
  @@map("favorite_vendors")
}

// Site-wide config (banners, etc.) — admin-editable
model SiteConfig {
  key   String @id
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@map("site_config")
}

model MarketingCampaign {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  year      Int?
  metadata  Json?
  active    Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates MarketingTemplate[]

  @@index([active])
  @@map("marketing_campaigns")
}

model MarketingTemplate {
  id                    String                   @id @default(cuid())
  slug                  String                   @unique
  name                  String
  category              String
  profile               MarketingTemplateProfile
  placeholderSchemaJson Json?
  safeHtmlPlaceholders  String[]                 @default([])
  companionTextKeys     String[]                 @default([])
  friendlyFilenameStem  String?
  defaultScale          Int                      @default(2)
  active                Boolean                  @default(true)
  version               Int                      @default(1)
  campaignId            String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  campaign MarketingCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assets   MarketingTemplateAsset[]
  renders  MarketingRender[]

  @@index([category, active])
  @@index([campaignId])
  @@map("marketing_templates")
}

model MarketingTemplateAsset {
  id            String                    @id @default(cuid())
  templateId    String
  kind          MarketingTemplateAssetKind
  name          String
  storageKey    String?
  inlineContent String?                   @db.Text
  mimeType      String?
  checksum      String?
  sizeBytes     Int?
  version       Int                       @default(1)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  template MarketingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, kind])
  @@unique([templateId, kind, name])
  @@map("marketing_template_assets")
}

model MarketingRender {
  id              String              @id @default(cuid())
  userId          String
  templateId      String
  templateVersion Int
  vendorId        String?
  eventId         String?
  marketId        String?
  variablesJson   Json
  scale           Int
  status          MarketingRenderStatus @default(QUEUED)
  errorMessage    String?             @db.Text
  pngOutputsJson  Json?
  textOutputsJson Json?
  startedAt       DateTime?
  finishedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template MarketingTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  vendor   VendorProfile?   @relation("MarketingRenderVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  event    Event?           @relation("MarketingRenderEvent", fields: [eventId], references: [id], onDelete: SetNull)
  market   Market?          @relation("MarketingRenderMarket", fields: [marketId], references: [id], onDelete: SetNull)
  folders  MarketingRenderFolder[]
  tags     MarketingRenderTag[]

  @@index([userId, createdAt])
  @@index([templateId, createdAt])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("marketing_renders")
}

model MarketingFolder {
  id          String   @id @default(cuid())
  name        String
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  renders   MarketingRenderFolder[]

  @@index([createdById, createdAt])
  @@index([deletedAt])
  @@map("marketing_folders")
}

model MarketingTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  renders MarketingRenderTag[]

  @@map("marketing_tags")
}

model MarketingRenderFolder {
  renderId String
  folderId String
  createdAt DateTime @default(now())

  render MarketingRender @relation(fields: [renderId], references: [id], onDelete: Cascade)
  folder MarketingFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([renderId, folderId])
  @@index([folderId, createdAt])
  @@map("marketing_render_folders")
}

model MarketingRenderTag {
  renderId String
  tagId    String
  createdAt DateTime @default(now())

  render MarketingRender @relation(fields: [renderId], references: [id], onDelete: Cascade)
  tag    MarketingTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([renderId, tagId])
  @@index([tagId, createdAt])
  @@map("marketing_render_tags")
}

// ─── Application Forms (admin-configurable) ─────────────────────────

enum ApplicationFormType {
  VENDOR
  MARKET
  VENDOR_VERIFICATION
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
  DUPLICATE
}

enum MarketingTemplateProfile {
  SQUARE
  IG_STORY
}

enum MarketingTemplateAssetKind {
  HTML
  TEXT
  IMAGE
}

enum MarketingRenderStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

model ApplicationForm {
  id          String              @id @default(cuid())
  type        ApplicationFormType @unique
  title       String
  description String?             @db.Text
  fields      Json // Array<{ id, label, type, required, options?, placeholder?, helpText? }>
  active      Boolean             @default(true)

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("application_forms")
}

model Application {
  id        String            @id @default(cuid())
  formId    String
  userId    String?
  status    ApplicationStatus @default(PENDING)
  answers   Json // Record<fieldId, value>
  name      String
  email     String
  notes     String?           @db.Text
  reviewedAt DateTime?
  reviewedBy String?

  form ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formId, status])
  @@index([status])
  @@map("applications")
}

// Maintenance mode: single row, id = "default"
enum MaintenanceMode {
  OFF
  MAINTENANCE_ADMIN_ONLY
  MAINTENANCE_PRIVILEGED
}

model SiteState {
  id              String          @id @default("default")
  mode            MaintenanceMode @default(OFF)
  messageTitle    String          @default("We'll be right back")
  messageBody     String?         @db.Text
  links           Json? // [{ label: string, url: string }]
  eta             DateTime?
  updatedByUserId String?
  updatedAt       DateTime        @updatedAt

  updatedBy User? @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("site_state")
}
