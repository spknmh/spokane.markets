{
  "name": "spokane-markets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:backfill-participation": "tsx scripts/backfill-vendor-participation.ts",
    "db:audit-neighborhoods": "tsx scripts/audit-neighborhoods.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "digest": "tsx scripts/weekly-digest.ts",
    "filter-alerts": "tsx scripts/filter-alerts.ts",
    "transform-venues": "tsx scripts/transform-venues-import.ts",
    "deps:check": "node scripts/dependency-updates.mjs",
    "deps:update:safe": "node scripts/dependency-updates.mjs --yes-safe",
    "deps:update:all": "node scripts/dependency-updates.mjs --yes-safe --yes-major",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.4",
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/search-js-react": "^1.5.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/nextjs": "^10.42.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
