{
  "name": "spokane-markets",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/spknmh/spokane.markets.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "dev:local:up": "docker compose -f docker-compose.local.yml up --build",
    "dev:local:down": "docker compose -f docker-compose.local.yml down --remove-orphans",
    "dev:local:reset": "docker compose -f docker-compose.local.yml down -v --remove-orphans",
    "dev:local:migrate": "docker compose -f docker-compose.local.yml run --rm web npx prisma migrate deploy",
    "dev:local:seed": "docker compose -f docker-compose.local.yml run --rm web npx prisma db seed",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "caddy:up": "docker compose -f caddy/docker-compose.yml up -d",
    "caddy:down": "docker compose -f caddy/docker-compose.yml down",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "marketing:worker": "tsx scripts/process-marketing-renders.ts",
    "db:backfill-participation": "tsx scripts/backfill-vendor-participation.ts",
    "db:audit-neighborhoods": "tsx scripts/audit-neighborhoods.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "digest": "tsx scripts/weekly-digest.ts",
    "filter-alerts": "tsx scripts/filter-alerts.ts",
    "transform-venues": "tsx scripts/transform-venues-import.ts",
    "deps:check": "node scripts/dependency-updates.mjs",
    "deps:update:safe": "node scripts/dependency-updates.mjs --yes-safe",
    "deps:update:all": "node scripts/dependency-updates.mjs --yes-safe --yes-major",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.4",
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/search-js-react": "^1.5.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.42.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.13.0",
    "puppeteer-core": "^24.8.2",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.71.2",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.10",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "kysely": "^0.28.14",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0",
    "basic-ftp": "^5.3.0",
    "protocol-buffers-schema": "^3.6.1",
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "vite": "^8.0.10",
    "defu": "^6.1.5"
  }
}
