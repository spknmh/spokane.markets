{
	email webmaster@spokane.markets
	servers :443 {
		protocols h1 h2 h3
	}
}

spokane.markets {
	 @env_probe path_regexp env \.env(\.(swp|qa|dist|demo|ci|uat|backup|example|old|defaults|preview|sample|save|production|local|staging|test|dev|prod|bak|stage))?$
	handle @env_probe {
			respond 404
	}
	tls {
		issuer acme {
			disable_tlsalpn_challenge
		}
	}

	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	handle_path /uploads/* {
		header Content-Disposition "inline"
		header X-Content-Type-Options "nosniff"
		@html path *.html *.htm *.svg
		respond @html 403
		root * /srv/uploads
		file_server
	}

	# The app does not serve websocket endpoints; reject scanner/websocket probes
	# early so they do not appear as upstream 502 EOF errors.
	@ws_upgrade {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	respond @ws_upgrade 400

	handle {
		reverse_proxy web:3000 {
			lb_retries 2
			lb_try_duration 5s
			fail_duration 30s

			health_uri /api/health/live
			health_interval 10s
			health_timeout 5s

			transport http {
				dial_timeout 5s
				response_header_timeout 30s
				read_timeout 30s
				write_timeout 30s
			}
		}
	}
}

analytics.spokane.markets {
	tls {
		issuer acme {
			disable_tlsalpn_challenge
		}
	}

	encode zstd gzip
	reverse_proxy umami:3000
}